{
  "name": "kolibri-theme-system",
  "version": "0.1.0",
  "description": "A modern UI theming system inspired by Kolibri and the Kolibri Design System.",
  "type": "module",
  "license": "MIT",
  "private": false,
  "sideEffects": [
    "*.css",
    "src/css/*.css"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/kolibri-theme-system.cjs",
  "module": "./dist/kolibri-theme-system.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/kolibri-theme-system.js",
      "require": "./dist/kolibri-theme-system.cjs"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview"
  },
  "keywords": [
    "kolibri",
    "theme",
    "design-system",
    "tokens",
    "css-variables",
    "accessibility"
  ],
  "author": "",
  "devDependencies": {
    "@types/node": "^20.14.10",
    "typescript": "^5.5.3",
    "vite": "^5.3.3",
    "vitest": "^2.0.2"
  }
}
